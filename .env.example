SPREADSHEET_ID=
SHEET_TAB=Draft Quote Sales Touch
# Optional: comma-separated same-shape tabs to sync with the same dataset
SHEET_TABS=
DASHBOARD_SHEET_TAB=Draft Quote Sales Touch
QUOTE_LIMIT=100
QUOTE_PAGE_SIZE=5
TZ=America/Los_Angeles
ALLOW_DEBUG_COMMANDS=false
# Local default is true, Cloud Run default is false
ALLOW_LOCAL_SHEETS_FALLBACK=

# Shared repo deploy split
# Sync service:
# FUNCTION_TARGET=kcSalesSync
# FUNCTION_SOURCE=dist/function.js
# Dashboard service:
# FUNCTION_TARGET=kcSalesDashboard
# FUNCTION_SOURCE=dist/dashboard-function.js

JOBBER_ACCESS_TOKEN=
JOBBER_CLIENT_ID=
JOBBER_CLIENT_SECRET=
JOBBER_REFRESH_TOKEN=
# Optional Secret Manager resource used when Jobber rotates the refresh token.
# Default: projects/823212137840/secrets/KC_SALES_SYNC_JOBBER_REFRESH_TOKEN
JOBBER_REFRESH_TOKEN_SECRET=
JOBBER_API_URL=https://api.getjobber.com/api/graphql
JOBBER_API_VERSION=2025-04-16
JOBBER_REQUEST_DELAY_MS=750
JOBBER_NOTES_PAGE_SIZE=20

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Optional local fallback if using gog instead of direct OAuth envs
GOG_ACCOUNT=
GOG_CREDENTIALS_PATH=
